<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Manage Users : JourneySpark Travel Planner</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="app-body">
    <%- include('partials/navbar') %>

    <div class="app-shell">
        <div class="app-main">
            <main class="app-content">
                <%- include('partials/alerts') %>

                <section class="welcome-row">
                    <a href="/admin" class="back-link">&larr; Back to Admin Dashboard</a>
                    <h1>Manage Users</h1>
                    <p>View every account, promote or demote roles, and remove accounts.</p>
                </section>

                <form action="/admin/users" method="GET" class="table-actions" style="margin-bottom: 18px;">
                    <input type="text" name="q" class="form-control" placeholder="Search by name or email&hellip;"
                           value="<%= search %>" style="max-width: 280px;">
                    <button type="submit" class="btn btn-outline btn-sm">Search</button>
                    <% if (search) { %>
                        <a href="/admin/users" class="btn btn-outline btn-sm">Clear</a>
                    <% } %>
                </form>

                <% if (users.length === 0 && search) { %>
                    <section class="empty-panel">
                        <svg class="icon empty-panel-icon"><use href="/images/icons.svg#icon-group"></use></svg>
                        <h2>No matches for "<%= search %>"</h2>
                        <p class="empty-state">Try a different name or email, or <a href="/admin/users">clear the search</a>.</p>
                    </section>
                <% } else if (users.length === 0) { %>
                    <section class="empty-panel">
                        <svg class="icon empty-panel-icon"><use href="/images/icons.svg#icon-group"></use></svg>
                        <h2>No users yet</h2>
                        <p class="empty-state">Registered accounts will show up here.</p>
                    </section>
                <% } else { %>
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Full Name</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Joined</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(function(u) { %>
                                    <tr>
                                        <td><%= u.fullName %></td>
                                        <td><%= u.email %></td>
                                        <td>
                                            <% if (u.role === 'admin') { %>
                                                <span class="role-badge role-admin">Admin</span>
                                            <% } else { %>
                                                <span class="role-badge role-traveler">Traveler</span>
                                            <% } %>
                                        </td>
                                        <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
                                        <td>
                                            <% if (u.userId === user.userId) { %>
                                                <span class="empty-state">This is you</span>
                                            <% } else { %>
                                                <div class="table-actions">
                                                    <form action="/admin/users/<%= u.userId %>/role" method="POST">
                                                        <input type="hidden" name="role" value="<%= u.role === 'admin' ? 'traveler' : 'admin' %>">
                                                        <button type="submit" class="btn btn-outline btn-sm">
                                                            <%= u.role === 'admin' ? 'Demote to Traveler' : 'Promote to Admin' %>
                                                        </button>
                                                    </form>
                                                    <form action="/admin/users/<%= u.userId %>/delete" method="POST"
                                                          onsubmit="return confirm('Delete this user? This cannot be undone.');">
                                                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                                    </form>
                                                </div>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </main>
        </div>
    </div>
    <script src="/js/auth.js"></script>
</body>
</html>
