<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Reset Password : Noxelle Travel</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page-body">
    <%- include('partials/navbar') %>

    <main class="auth-page-shell">
        <div class="auth-route-decoration" aria-hidden="true">
            <svg class="icon"><use href="/images/icons.svg#icon-plane"></use></svg>
        </div>
        <div class="auth-wing-decoration" aria-hidden="true"></div>

        <div class="auth-ticket">
            <div class="auth-ticket-stub">
                <div class="auth-ticket-stub-top">
                    <svg class="icon auth-ticket-plane" aria-hidden="true"><use href="/images/icons.svg#icon-plane"></use></svg>
                    <p class="auth-ticket-logo">Noxelle Travel</p>
                    <span class="auth-ticket-line" aria-hidden="true"></span>
                </div>
                <p class="auth-ticket-message">
                    ENJOY<br>
                    THE JOURNEY,<br>
                    COLLECT<br>
                    MEMORIES.
                </p>
            </div>

            <div class="auth-ticket-perforation" aria-hidden="true"></div>

            <div class="auth-ticket-content">
                <p class="auth-eyebrow">ACCOUNT RECOVERY</p>
                <h1 class="auth-heading">Choose a new password</h1>
                <p class="auth-ticket-desc">Set a new password for your traveler account.</p>

                <%- include('partials/alerts') %>

                <form action="/reset-password/<%= token %>" method="POST" class="auth-ticket-form" novalidate>
                    <div class="form-group">
                        <label for="password">New password</label>
                        <div class="password-wrap">
                            <input type="password" id="password" name="password" placeholder="Create a new password"
                                   minlength="8" required autocomplete="new-password">
                            <button type="button" class="toggle-password" data-target="password" aria-label="Show password">
                                <svg class="icon"><use href="/images/icons.svg#icon-eye"></use></svg>
                            </button>
                        </div>
                        <div class="password-requirements">
                            <p>Password must contain at least 8 characters, including:</p>
                            <ul>
                                <li>One uppercase letter</li>
                                <li>One lowercase letter</li>
                                <li>One number</li>
                                <li>One symbol</li>
                            </ul>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="confirmPassword">Confirm new password</label>
                        <div class="password-wrap">
                            <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Repeat the new password"
                                   minlength="8" required autocomplete="new-password">
                            <button type="button" class="toggle-password" data-target="confirmPassword" aria-label="Show password">
                                <svg class="icon"><use href="/images/icons.svg#icon-eye"></use></svg>
                            </button>
                        </div>
                        <p class="match-hint" data-match-hint hidden>Passwords do not match yet.</p>
                    </div>
                    <button type="submit" class="btn btn-primary btn-block">
                        <svg class="icon"><use href="/images/icons.svg#icon-plane"></use></svg>Save New Password</button>
                </form>

                <p class="auth-switch"><a href="/login">Back to login</a></p>
            </div>
        </div>
    </main>

    <script src="/js/auth.js"></script>
</body>
</html>
