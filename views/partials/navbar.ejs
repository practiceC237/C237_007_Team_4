<style>
    /* Force topbar brand name, plane icon, and text navigation links to be white */
    .app-topbar .brand,
    .app-topbar .brand-name,
    .app-topbar .brand-mark,
    .app-topbar .brand-mark svg,
    .app-topbar .brand-mark use,
    .app-topbar .nav-links a:not(.btn) {
        color: #ffffff !important;
        fill: #ffffff !important;
    }

    /* Hover color for text links in the topbar */
    .app-topbar .nav-links a:not(.btn):hover {
        color: #e2e8f0 !important;
        opacity: 0.9;
    }

    /* Style for Admin Dashboard button to keep it visible on dark topbar */
    .app-topbar .btn-admin-dash {
        color: #ffffff !important;
        border: 1px solid rgba(255, 255, 255, 0.6) !important;
        background-color: rgba(255, 255, 255, 0.15) !important;
        padding: 0.4rem 0.85rem;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.2s ease;
    }

    .app-topbar .btn-admin-dash:hover {
        background-color: #ffffff !important;
        color: #0f172a !important;
    }

    /* Layout alignment */
    .app-topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 1.5rem;
    }

    .app-topbar .nav-links {
        display: flex;
        align-items: center;
        gap: 1.25rem;
    }

    .app-topbar .topbar-user {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
</style>

<% if (user) { %>
    <% if (user.role === 'admin') { %>
        <!-- ================================================== -->
        <!-- Admin Top Navigation Bar                           -->
        <!-- ================================================== -->
        <header class="app-topbar navbar navbar-admin">
            <button type="button" class="nav-toggle sidebar-toggle" aria-label="Toggle sidebar">
                <svg class="icon"><use href="/images/icons.svg#icon-menu"></use></svg>
            </button>
            <a class="brand" href="/">
                <span class="brand-mark"><svg class="icon"><use href="/images/icons.svg#icon-plane"></use></svg></span>
                <span class="brand-name">JourneySpark Travel Planner</span>
            </a>
            
            <nav class="nav-links">
                <a href="/">Home</a>
                <a href="/admin" class="btn-admin-dash">Admin Dashboard</a>
                
                <div class="topbar-user">
                    <span class="avatar avatar-admin"><%= user.fullName ? user.fullName.charAt(0).toUpperCase() : 'A' %></span>
                    <div class="topbar-user-meta">
                        <span class="topbar-name" style="color: #ffffff;"><%= user.fullName %></span>
                        <span class="role-badge role-admin">Admin</span>
                    </div>
                </div>

                <form action="/logout" method="POST" class="nav-logout-form">
                    <button type="submit" class="btn btn-primary">Log Out</button>
                </form>
            </nav>
        </header>

    <% } else { %>
        <!-- ================================================== -->
        <!-- Logged-in Traveler Top Navigation Bar              -->
        <!-- ================================================== -->
        <header class="app-topbar navbar navbar-user">
            <a class="brand" href="/">
                <span class="brand-mark"><svg class="icon"><use href="/images/icons.svg#icon-plane"></use></svg></span>
                <span class="brand-name">JourneySpark Travel Planner</span>
            </a>
            
            <button type="button" class="nav-toggle" aria-label="Toggle navigation">
                <svg class="icon"><use href="/images/icons.svg#icon-menu"></use></svg>
            </button>

            <nav class="nav-links">
                <a href="/">Home</a>
                <a href="/budget">My Budget</a>

                <div class="topbar-user">
                    <span class="avatar"><%= user.fullName ? user.fullName.charAt(0).toUpperCase() : 'U' %></span>
                    <div class="topbar-user-meta">
                        <span class="topbar-name" style="color: #ffffff;"><%= user.fullName %></span>
                        <span class="role-badge role-traveler">Traveler</span>
                    </div>
                </div>

                <form action="/logout" method="POST" class="nav-logout-form">
                    <button type="submit" class="btn btn-primary">Log Out</button>
                </form>
            </nav>
        </header>
    <% } %>

<% } else { %>
    <!-- ================================================== -->
    <!-- Guest / Public Visitor Navigation Bar              -->
    <!-- ================================================== -->
    <header class="navbar navbar-guest">
        <a class="brand" href="/">
            <span class="brand-mark"><svg class="icon"><use href="/images/icons.svg#icon-plane"></use></svg></span>
            <span class="brand-name">JourneySpark Travel Planner</span>
        </a>
        <button type="button" class="nav-toggle" aria-label="Toggle navigation">
            <svg class="icon"><use href="/images/icons.svg#icon-menu"></use></svg>
        </button>
        <nav class="nav-links">
            <a href="/">Home</a>
            <a href="/#destinations">Destinations</a>
            <a class="btn btn-outline" href="/login">Login</a>
            <a class="btn btn-primary" href="/register">Register</a>
        </nav>
    </header>
<% } %>