<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Create Account — Noxelle Travel</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body sky">
    <main class="auth-wrap">
        <div class="auth-brand-top">
            <a class="brand" href="/">
                <span class="brand-mark"><svg class="icon"><use href="/images/icons.svg#icon-plane"></use></svg></span>
                <span class="brand-name">Noxelle Travel</span>
            </a>
        </div>

        <div class="auth-card">
            <h1 class="auth-title"><svg class="icon"><use href="/images/icons.svg#icon-plane"></use></svg>Create Account</h1>
            <p class="auth-sub">Join Noxelle Travel and explore the world.</p>

            <%- include('partials/alerts') %>

            <form action="/register" method="POST" class="auth-form" novalidate>
                <div class="form-group">
                    <label for="fullName">Full Name</label>
                    <input type="text" id="fullName" name="fullName" placeholder="Enter your full name"
                           value="<%= formData && formData.fullName ? formData.fullName : '' %>" required autocomplete="name">
                </div>
                <div class="form-group">
                    <label for="email">Email address</label>
                    <input type="email" id="email" name="email" placeholder="traveler@example.com"
                           value="<%= formData && formData.email ? formData.email : '' %>" required autocomplete="email">
                </div>
                <div class="form-group">
                    <label for="password">Password <span class="label-hint">(at least 8 characters)</span></label>
                    <div class="password-wrap">
                        <input type="password" id="password" name="password" placeholder="Create a password" required autocomplete="new-password">
                        <button type="button" class="toggle-password" data-target="password" aria-label="Show password">
                            <svg class="icon"><use href="/images/icons.svg#icon-eye"></use></svg>
                        </button>
                    </div>
                </div>
                <div class="form-group">
                    <label for="confirmPassword">Confirm Password</label>
                    <div class="password-wrap">
                        <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm your password" required autocomplete="new-password">
                        <button type="button" class="toggle-password" data-target="confirmPassword" aria-label="Show password">
                            <svg class="icon"><use href="/images/icons.svg#icon-eye"></use></svg>
                        </button>
                    </div>
                    <p class="match-hint" data-match-hint hidden>Passwords do not match yet.</p>
                </div>
                <div class="form-group">
                    <label for="role">Role</label>
                    <select id="role" name="role" class="form-control" required>
                        <option value="" disabled <%= !formData || !formData.role ? 'selected' : '' %>>Select your role</option>
                        <option value="traveler" <%= formData && formData.role === 'traveler' ? 'selected' : '' %>>Traveler</option>
                        <option value="admin" <%= formData && formData.role === 'admin' ? 'selected' : '' %>>Admin</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary btn-block">
                    <svg class="icon"><use href="/images/icons.svg#icon-plane"></use></svg>Create Account</button>
            </form>

            <p class="auth-switch">Already have an account? <a href="/login">Login</a></p>
        </div>
    </main>
    <script src="/js/auth.js"></script>
</body>
</html>
