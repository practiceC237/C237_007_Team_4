<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Create Account : JourneySpark Travel Planner</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page-body">
    <%- include('partials/navbar') %>

    <main class="auth-page-shell">
        <div class="auth-route-decoration" aria-hidden="true">
            <svg class="icon"><use href="/images/icons.svg#icon-plane"></use></svg>
        </div>
        <div class="auth-wing-decoration" aria-hidden="true"></div>

        <div class="auth-ticket">
            <div class="auth-ticket-stub">
                <div class="auth-ticket-stub-top">
                    <svg class="icon auth-ticket-plane" aria-hidden="true"><use href="/images/icons.svg#icon-plane"></use></svg>
                    <p class="auth-ticket-logo">JourneySpark Travel Planner</p>
                    <span class="auth-ticket-line" aria-hidden="true"></span>
                </div>
                <p class="auth-ticket-message">
                    ENJOY<br>
                    THE JOURNEY,<br>
                    COLLECT<br>
                    MEMORIES.
                </p>
            </div>

            <div class="auth-ticket-perforation" aria-hidden="true"></div>

            <div class="auth-ticket-content">
                <p class="auth-eyebrow">CREATE ACCOUNT</p>
                <h1 class="auth-heading">Join JourneySpark Travel Planner and explore the world.</h1>

                <%- include('partials/alerts') %>

                <form action="/register" method="POST" class="auth-ticket-form" novalidate>
                    <div class="form-group">
                        <label for="fullName">Full Name</label>
                        <input type="text" id="fullName" name="fullName" placeholder="Enter your full name"
                               value="<%= formData && formData.fullName ? formData.fullName : '' %>" required autocomplete="name">
                    </div>
                    <div class="form-group">
                        <label for="email">Email address</label>
                        <input type="email" id="email" name="email" placeholder="traveler@example.com"
                               value="<%= formData && formData.email ? formData.email : '' %>" required autocomplete="email">
                    </div>
                    <div class="form-group">
                        <label for="password">Password</label>
                        <div class="password-wrap">
                            <input type="password" id="password" name="password" placeholder="Create a password"
                                   minlength="8" required autocomplete="new-password">
                            <button type="button" class="toggle-password" data-target="password" aria-label="Show password">
                                <svg class="icon"><use href="/images/icons.svg#icon-eye"></use></svg>
                            </button>
                        </div>
                        <div class="password-requirements">
                            <p>Password must contain at least 8 characters, including:</p>
                            <ul>
                                <li>One uppercase letter</li>
                                <li>One lowercase letter</li>
                                <li>One number</li>
                                <li>One symbol</li>
                            </ul>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="confirmPassword">Confirm Password</label>
                        <div class="password-wrap">
                            <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm your password"
                                   minlength="8" required autocomplete="new-password">
                            <button type="button" class="toggle-password" data-target="confirmPassword" aria-label="Show password">
                                <svg class="icon"><use href="/images/icons.svg#icon-eye"></use></svg>
                            </button>
                        </div>
                        <p class="match-hint" data-match-hint hidden>Passwords do not match yet.</p>
                    </div>
                    <button type="submit" class="btn btn-primary btn-block">
                        <svg class="icon"><use href="/images/icons.svg#icon-plane"></use></svg>Create Account</button>
                </form>

                <p class="auth-switch">Already have an account? <a href="/login">Log in</a></p>
            </div>
        </div>
    </main>

    <script src="/js/auth.js"></script>
</body>
</html>
