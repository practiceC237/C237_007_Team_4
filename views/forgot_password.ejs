<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Forgot Password : JourneySpark Travel Planner</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page-body">
    <%- include('partials/navbar') %>

    <main class="auth-page-shell">
        <div class="auth-route-decoration" aria-hidden="true">
            <svg class="icon"><use href="/images/icons.svg#icon-plane"></use></svg>
        </div>
        <div class="auth-wing-decoration" aria-hidden="true"></div>

        <div class="auth-ticket">
            <div class="auth-ticket-stub">
                <div class="auth-ticket-stub-top">
                    <svg class="icon auth-ticket-plane" aria-hidden="true"><use href="/images/icons.svg#icon-plane"></use></svg>
                    <p class="auth-ticket-logo">JourneySpark Travel Planner</p>
                    <span class="auth-ticket-line" aria-hidden="true"></span>
                </div>
                <p class="auth-ticket-message">
                    ENJOY<br>
                    THE JOURNEY,<br>
                    COLLECT<br>
                    MEMORIES.
                </p>
            </div>

            <div class="auth-ticket-perforation" aria-hidden="true"></div>

            <div class="auth-ticket-content">
                <p class="auth-eyebrow">ACCOUNT RECOVERY</p>
                <h1 class="auth-heading">Forgot your password?</h1>
                <p class="auth-ticket-desc">Enter your email and we'll generate a reset link for your account.</p>

                <%- include('partials/alerts') %>

                <form action="/forgot-password" method="POST" class="auth-ticket-form" novalidate>
                    <div class="form-group">
                        <label for="email">Email address</label>
                        <input type="email" id="email" name="email" placeholder="traveler@example.com" required autocomplete="email">
                    </div>
                    <button type="submit" class="btn btn-primary btn-block">
                        <svg class="icon"><use href="/images/icons.svg#icon-plane"></use></svg>Generate Reset Link</button>
                </form>

                <p class="auth-switch">Remembered it? <a href="/login">Back to login</a></p>
            </div>
        </div>
    </main>

    <script src="/js/auth.js"></script>
</body>
</html>
