<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Access Denied — Noxelle Travel</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body sky">
    <main class="denied-wrap">
        <div class="boarding-pass">
            <div class="pass-header">
                <svg class="icon"><use href="/images/icons.svg#icon-plane"></use></svg>
                <span>BOARDING PASS</span>
            </div>
            <div class="pass-body">
                <div class="pass-main">
                    <svg class="icon pass-plane"><use href="/images/icons.svg#icon-plane"></use></svg>
                    <div class="pass-status-label">
                        <svg class="icon"><use href="/images/icons.svg#icon-lock"></use></svg>STATUS
                    </div>
                    <div class="pass-status">CANCELLED</div>
                    <p class="pass-message">You don't have permission to access this page.</p>
                </div>
                <div class="pass-divider" aria-hidden="true"></div>
                <div class="pass-stub" aria-hidden="true">
                    <div class="barcode"></div>
                </div>
            </div>
        </div>
        <div class="denied-actions">
            <a class="btn btn-primary" href="<%= user ? '/dashboard' : '/login' %>">Return to My Journey</a>
            <p class="denied-brand">Noxelle Travel &middot; Your journey, our priority.</p>
        </div>
    </main>
    <script src="/js/auth.js"></script>
</body>
</html>
