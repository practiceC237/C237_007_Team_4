<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin Dashboard : JourneySpark Travel Planner</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="app-body">
    <%- include('partials/apptopbar') %>

    <div class="app-shell">
        <%- include('partials/sidebar', { area: 'admin', active: '/admin' }) %>

        <div class="app-main">
            <main class="app-content">
                <%- include('partials/alerts') %>

                <section class="welcome-row">
                    <h1>Admin Dashboard</h1>
                    <p>Manage travelers, trips and reports for JourneySpark Travel Planner.</p>
                </section>

                <section class="stat-grid">
                    <div class="stat-card">
                        <span class="stat-icon"><svg class="icon"><use href="/images/icons.svg#icon-group"></use></svg></span>
                        <div>
                            <div class="stat-value"><%= counts.totalUsers %></div>
                            <div class="stat-label">Total Users</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <span class="stat-icon"><svg class="icon"><use href="/images/icons.svg#icon-passport"></use></svg></span>
                        <div>
                            <div class="stat-value"><%= counts.totalAdmins %></div>
                            <div class="stat-label">Total Admins</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <span class="stat-icon"><svg class="icon"><use href="/images/icons.svg#icon-route"></use></svg></span>
                        <div>
                            <div class="stat-value"><%= counts.totalDestinations %></div>
                            <div class="stat-label">Total Destinations</div>
                        </div>
                    </div>
                </section>

                <section class="page-header">
                    <h1>Quick Actions</h1>
                </section>
                <section class="card-grid">
                    <a href="/admin/users" class="panel-card">
                        <svg class="icon panel-icon"><use href="/images/icons.svg#icon-group"></use></svg>
                        <h3>Manage Users</h3>
                        <p class="empty-state">View traveler and admin accounts, change roles, or remove accounts.</p>
                    </a>
                    <a href="/admin/destinations" class="panel-card">
                        <svg class="icon panel-icon"><use href="/images/icons.svg#icon-route"></use></svg>
                        <h3>Manage Destinations</h3>
                        <p class="empty-state">Browse destinations travelers have used and rename them if needed.</p>
                    </a>
                </section>
            </main>
        </div>
    </div>
    <script src="/js/auth.js"></script>
</body>
</html>
