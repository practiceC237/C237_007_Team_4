<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Packing Item - JourneySpark</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="app-body">
  <%- include('partials/navbar') %>

  <main class="app-content">
    <%- include('partials/alerts') %>
    <div class="packing-card" style="max-width: 600px; margin: 0 auto;">
      <h2>Add Packing Item</h2>

      <form action="/trips/<%= tripId %>/packing-list/add" method="POST">
        <div class="form-group">
          <label>Item Name</label>
          <input type="text" name="item_name" placeholder="e.g. Passport, Sunscreen, Power Bank" required>
        </div>

        <div class="form-group">
          <label>Category</label>
          <select name="category">
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>"><%= cat %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label>Quantity</label>
          <input type="number" name="quantity" value="1" min="1" required>
        </div>

        <div class="form-actions" style="display: flex; gap: 12px; margin-top: 16px;">
          <button type="submit" class="btn btn-primary">Add Item</button>
          <a href="/trips/<%= tripId %>/packing-list" class="btn btn-white">Cancel</a>
        </div>
      </form>
    </div>
  </main>
</body>
</html>